{#
    Beastmode keyboard shortcut - Always loads in dev mode
    Allows toggling beastmode with Ctrl+B / Cmd+B
    Note: No <script> tags needed - registerScript() adds them automatically
#}
{% set commerceInstalled = craft.app.plugins.isPluginInstalled('commerce') %}
{% set hasCategories = craft.app.categories.allGroups|length > 0 %}
{% apply spaceless %}
{% verbatim %}
(function() {
    // Beastmode keyboard shortcut (Ctrl+B / Cmd+B)
    // Only runs once per page load
    if (window.bonsaiBeastmodeShortcutInitialized) {
        return;
    }
    window.bonsaiBeastmodeShortcutInitialized = true;

    console.log('🔧 Beastmode Options loaded. Press Ctrl/Cmd + B to toggle.');

    let modal = null;

    function createModal() {
        modal = document.createElement('div');
        modal.style.cssText = `
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.8);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 99999;
            backdrop-filter: blur(4px);
        `;

        const content = document.createElement('div');
        content.style.cssText = `
            background: #1e1e1e;
            border: 1px solid #454545;
            border-radius: 8px;
            padding: 24px;
            max-width: 500px;
            width: 90%;
            box-shadow: 0 8px 32px rgba(0,0,0,0.5);
            font-family: 'SF Mono', 'Monaco', 'Inconsolata', 'Roboto Mono', 'Consolas', 'Courier New', monospace;
        `;

        const currentUrl = new URL(window.location.href);
        const beastmodeParam = currentUrl.searchParams.get('beastmode') || '';

        // Parse currently active modes (could be comma-separated)
        const activeModes = beastmodeParam ? beastmodeParam.split(',').map(m => m.trim()) : [];
        const isAllMode = activeModes.includes('all') || beastmodeParam === '';

        const beastmodeOptions = [
            { value: 'entry', label: 'Entries', description: 'Show debug for entry templates' },
            { value: 'item', label: 'Items', description: 'Show debug for item templates' },
            { value: 'matrix', label: 'Matrix Blocks', description: 'Show debug for matrix block templates' },
            { value: 'asset', label: 'Assets', description: 'Show debug for asset templates' },
        ];
        {% endverbatim %}
        {% if hasCategories %}
        beastmodeOptions.push({ value: 'category', label: 'Categories', description: 'Show debug for category templates' });
        {% endif %}
        {% if commerceInstalled %}
        beastmodeOptions.push({ value: 'product', label: 'Products', description: 'Show debug for product templates' });
        {% endif %}
        {% verbatim %}

        let html = `
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h3 style="color: #569cd6; margin: 0; font-size: 16px; font-weight: bold;">🔧 Beastmode Options</h3>
                <button id="bonsai-modal-close" style="background: none; border: none; color: #808080; font-size: 24px; cursor: pointer; padding: 0; line-height: 1; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center;" title="Close (Esc)">×</button>
            </div>
            <p style="color: #9cdcfe; font-size: 12px; margin-bottom: 16px; line-height: 1.4;">
                Select template types to show debug overlays (multi-select):
            </p>
            <div style="display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px;">
                <label style="
                    display: flex;
                    align-items: center;
                    padding: 12px;
                    background: rgba(86, 156, 214, 0.1);
                    border: 1px solid rgba(86, 156, 214, 0.2);
                    border-radius: 6px;
                    cursor: pointer;
                    transition: all 150ms ease;
                    font-size: 13px;
                " class="beastmode-option beastmode-all-option">
                    <input type="checkbox" id="beastmode-all" value="all" style="
                        margin-right: 12px;
                        width: 16px;
                        height: 16px;
                        cursor: pointer;
                    " ${isAllMode && beastmodeParam !== '' ? 'checked' : ''}>
                    <div style="flex: 1;">
                        <div style="font-weight: bold; margin-bottom: 4px; color: #9cdcfe;">
                            All Templates
                        </div>
                        <div style="font-size: 11px; color: #808080; font-style: italic;">
                            Show debug for all template types
                        </div>
                    </div>
                </label>
        `;

        beastmodeOptions.forEach(option => {
            const isChecked = !isAllMode && activeModes.includes(option.value);
            html += `
                <label style="
                    display: flex;
                    align-items: center;
                    padding: 12px;
                    background: rgba(86, 156, 214, 0.1);
                    border: 1px solid rgba(86, 156, 214, 0.2);
                    border-radius: 6px;
                    cursor: pointer;
                    transition: all 150ms ease;
                    font-size: 13px;
                " class="beastmode-option">
                    <input type="checkbox" class="beastmode-type" value="${option.value}" style="
                        margin-right: 12px;
                        width: 16px;
                        height: 16px;
                        cursor: pointer;
                    " ${isChecked ? 'checked' : ''}>
                    <div style="flex: 1;">
                        <div style="font-weight: bold; margin-bottom: 4px; color: #9cdcfe;">
                            ${option.label}
                        </div>
                        <div style="font-size: 11px; color: #808080; font-style: italic;">
                            ${option.description}
                        </div>
                    </div>
                </label>
            `;
        });

        html += `
            </div>
            <div style="display: flex; gap: 8px; margin-bottom: 16px;">
                <button id="beastmode-apply" style="
                    flex: 1;
                    padding: 12px;
                    background: rgba(78, 201, 176, 0.15);
                    border: 1px solid rgba(78, 201, 176, 0.3);
                    border-radius: 6px;
                    color: #4ec9b0;
                    font-weight: bold;
                    cursor: pointer;
                    transition: all 150ms ease;
                    font-size: 13px;
                    font-family: 'SF Mono', 'Monaco', 'Inconsolata', 'Roboto Mono', 'Consolas', 'Courier New', monospace;
                ">Apply</button>
                <button id="beastmode-disable" style="
                    flex: 1;
                    padding: 12px;
                    background: rgba(244, 71, 71, 0.15);
                    border: 1px solid rgba(244, 71, 71, 0.3);
                    border-radius: 6px;
                    color: #f44747;
                    font-weight: bold;
                    cursor: pointer;
                    transition: all 150ms ease;
                    font-size: 13px;
                    font-family: 'SF Mono', 'Monaco', 'Inconsolata', 'Roboto Mono', 'Consolas', 'Courier New', monospace;
                ">Disable</button>
            </div>
            <p style="color: #808080; font-size: 10px; margin: 0; text-align: center; font-style: italic;">
                Press Ctrl+B (Cmd+B on Mac) to toggle this menu
            </p>
        `;

        content.innerHTML = html;
        modal.appendChild(content);
        document.body.appendChild(modal);

        // Get references to checkboxes
        const allCheckbox = content.querySelector('#beastmode-all');
        const typeCheckboxes = content.querySelectorAll('.beastmode-type');
        const applyBtn = content.querySelector('#beastmode-apply');
        const disableBtn = content.querySelector('#beastmode-disable');
        const closeBtn = content.querySelector('#bonsai-modal-close');

        // Handle "All" checkbox logic
        allCheckbox.addEventListener('change', function() {
            if (this.checked) {
                // Uncheck all individual types when "All" is checked
                typeCheckboxes.forEach(cb => cb.checked = false);
            }
        });

        // Handle individual type checkboxes
        typeCheckboxes.forEach(checkbox => {
            checkbox.addEventListener('change', function() {
                if (this.checked) {
                    // Uncheck "All" when any individual type is checked
                    allCheckbox.checked = false;

                    // Check if all individual types are now checked
                    const allTypesChecked = Array.from(typeCheckboxes).every(cb => cb.checked);
                    if (allTypesChecked) {
                        // If all types are checked, switch to "All" mode
                        typeCheckboxes.forEach(cb => cb.checked = false);
                        allCheckbox.checked = true;
                    }
                }
            });
        });

        // Apply button - build URL and navigate
        applyBtn.addEventListener('click', function() {
            const newUrl = new URL(currentUrl);

            if (allCheckbox.checked) {
                // If "All" is checked, set beastmode=all
                newUrl.searchParams.set('beastmode', 'all');
            } else {
                // Build comma-separated list of checked types
                const checkedTypes = Array.from(typeCheckboxes)
                    .filter(cb => cb.checked)
                    .map(cb => cb.value);

                if (checkedTypes.length > 0) {
                    newUrl.searchParams.set('beastmode', checkedTypes.join(','));
                } else {
                    newUrl.searchParams.delete('beastmode');
                }
            }

            window.location.href = newUrl.href;
        });

        // Disable button - remove beastmode parameter
        disableBtn.addEventListener('click', function() {
            const newUrl = new URL(currentUrl);
            newUrl.searchParams.delete('beastmode');
            window.location.href = newUrl.href;
        });

        // Hover effects for labels
        const labels = content.querySelectorAll('.beastmode-option');
        labels.forEach(label => {
            label.addEventListener('mouseenter', function() {
                this.style.background = 'rgba(86, 156, 214, 0.2)';
            });
            label.addEventListener('mouseleave', function() {
                this.style.background = 'rgba(86, 156, 214, 0.1)';
            });
        });

        // Hover effects for buttons
        applyBtn.addEventListener('mouseenter', function() {
            this.style.background = 'rgba(78, 201, 176, 0.25)';
        });
        applyBtn.addEventListener('mouseleave', function() {
            this.style.background = 'rgba(78, 201, 176, 0.15)';
        });

        disableBtn.addEventListener('mouseenter', function() {
            this.style.background = 'rgba(244, 71, 71, 0.25)';
        });
        disableBtn.addEventListener('mouseleave', function() {
            this.style.background = 'rgba(244, 71, 71, 0.15)';
        });

        // Close button
        closeBtn.addEventListener('click', hideModal);
        closeBtn.addEventListener('mouseenter', function() {
            this.style.color = '#f44747';
        });
        closeBtn.addEventListener('mouseleave', function() {
            this.style.color = '#808080';
        });

        // Click outside to close
        modal.addEventListener('click', function(e) {
            if (e.target === modal) {
                hideModal();
            }
        });
    }

    function showModal() {
        if (!modal) {
            createModal();
        }
        modal.style.display = 'flex';
    }

    function hideModal() {
        if (modal) {
            modal.style.display = 'none';
        }
    }

    // Listen for Ctrl+B / Cmd+B
    document.addEventListener('keydown', function(e) {
        // Ctrl+B / Cmd+B: Toggle modal
        if ((e.ctrlKey || e.metaKey) && (e.key === 'b' || e.key === 'B')) {
            e.preventDefault();
            if (modal && modal.style.display === 'flex') {
                hideModal();
            } else {
                showModal();
            }
        }

        // Close on Escape
        if (e.key === 'Escape' && modal && modal.style.display === 'flex') {
            hideModal();
        }
    });
})();
{% endverbatim %}
{% endapply %}

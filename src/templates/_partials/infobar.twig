{#
    Simplified debug template for Bonsai Twig development workflow.
    
    This template provides basic debug information display without performance
    metrics or complex styling. Focuses on essential template resolution info
    and field handles for development use only.
    
    Features:
    - Template resolution hierarchy display
    - Field handles with Twig code generation
    - Simple context information
    - Zero production overhead (only rendered in devMode)
#}
{% set data = info|json_decode %}

{% apply spaceless %}
    <style>
        .bonsai-info__hover {
            position: relative;
            display: inline-block;
            isolation: isolate;
        }
        .bonsai-info__hover:hover {
            z-index: 99998;
            isolation: auto;
            pointer-events: none;
        }
        .bonsai-info__hover:hover > * {
            pointer-events: auto;
        }
        .bonsai-info__hover:hover .bonsai-info__text {
            opacity: 1 !important;
            visibility: visible !important;
            transition: opacity 200ms ease-in-out, visibility 0ms;
        }
        .bonsai-info__text {
            position: absolute;
            top: 0;
            left: 0;
            background: #1e1e1e;
            color: #d4d4d4;
            font-family: 'SF Mono', 'Monaco', 'Inconsolata', 'Roboto Mono', 'Consolas', 'Courier New', monospace;
            font-size: 12px;
            padding: 16px;
            min-width: 400px;
            max-width: 600px;
            overflow-x: auto;
            opacity: 0;
            visibility: hidden;
            border: 1px solid #454545;
            border-radius: 6px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3), 0 0 0 1px rgba(255,255,255,0.1);
            line-height: 1.5;
            transition: opacity 200ms ease-in-out, visibility 200ms ease-in-out;
            backdrop-filter: blur(10px);
            z-index: 99998;
        }
        .bonsai-info__header {
            border-bottom: 1px solid #454545;
            padding-bottom: 12px;
            margin-bottom: 12px;
        }
        .bonsai-info__header-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 8px;
        }
        .bonsai-info__title {
            color: #569cd6;
            font-weight: bold;
            font-size: 13px;
        }
        .bonsai-info__type-badge {
            background: #264f78;
            color: #9cdcfe;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 10px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .bonsai-info__type-badge--strategy {
            background: #4e3a1e;
            color: #dcdcaa;
        }
        .bonsai-info__element-info {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 11px;
        }
        .bonsai-info__element-title {
            color: #d4d4d4;
        }
        .bonsai-info__element-handle {
            color: #dcdcaa;
            font-family: 'SF Mono', 'Monaco', 'Inconsolata', 'Roboto Mono', 'Consolas', 'Courier New', monospace;
            background: rgba(220, 220, 170, 0.1);
            padding: 2px 6px;
            border-radius: 3px;
            cursor: pointer;
            transition: background 150ms ease, color 150ms ease;
            user-select: none;
        }
        .bonsai-info__element-handle:hover {
            background: rgba(220, 220, 170, 0.2);
            color: #f0f0aa;
        }
        .bonsai-info__element-handle:active {
            background: rgba(220, 220, 170, 0.3);
        }
        .bonsai-info__copyable {
            cursor: pointer;
            transition: background 150ms ease, color 150ms ease;
            user-select: none;
            position: relative;
        }
        .bonsai-info__copyable:hover {
            background: rgba(220, 220, 170, 0.2) !important;
        }
        .bonsai-info__copyable:active {
            background: rgba(220, 220, 170, 0.3) !important;
        }
        .bonsai-info__copy-tooltip {
            position: absolute;
            top: -25px;
            left: 50%;
            transform: translateX(-50%);
            background: #4ec9b0;
            color: #1e1e1e;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 10px;
            font-weight: 600;
            white-space: nowrap;
            opacity: 0;
            pointer-events: none;
            transition: opacity 150ms ease;
            z-index: 1;
        }
        .bonsai-info__copy-tooltip--visible {
            opacity: 1;
        }
        .bonsai-info__directory {
            margin-bottom: 12px;
        }
        .bonsai-info__directory-label {
            color: #569cd6;
            font-weight: 600;
            margin-bottom: 4px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .bonsai-info__directory-path {
            color: #ce9178;
            font-weight: 500;
            background: rgba(206, 145, 120, 0.1);
            padding: 4px 8px;
            border-radius: 4px;
            border-left: 3px solid #ce9178;
        }
        .bonsai-info__site-context {
            margin-bottom: 12px;
            padding: 8px;
            background: rgba(86, 156, 214, 0.1);
            border-radius: 4px;
            border-left: 3px solid #569cd6;
        }
        .bonsai-info__site-label {
            color: #569cd6;
            font-weight: 600;
            margin-bottom: 4px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .bonsai-info__site-item {
            margin: 2px 0;
            font-size: 11px;
            display: flex;
            justify-content: space-between;
        }
        .bonsai-info__site-key {
            color: #9cdcfe;
        }
        .bonsai-info__site-value {
            color: #ce9178;
            font-weight: 500;
        }
        .bonsai-info__templates {
            margin-bottom: 12px;
        }
        .bonsai-info__templates-label {
            color: #569cd6;
            font-weight: 600;
            margin-bottom: 8px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .bonsai-info__template-count {
            background: #264f78;
            color: #9cdcfe;
            padding: 2px 6px;
            border-radius: 10px;
            font-size: 9px;
            font-weight: 500;
        }
        .bonsai-info__template-hierarchy {
            margin: 8px 0;
        }
        .bonsai-info__template-group {
            margin-bottom: 8px;
        }
        .bonsai-info__template-group-label {
            color: #dcdcaa;
            font-size: 10px;
            font-weight: 600;
            margin-bottom: 4px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .bonsai-info__template-list {
            margin: 0;
            padding: 0;
            list-style: none;
        }
        .bonsai-info__template-item {
            padding: 3px 0;
            line-height: 1.4;
            margin-bottom: 2px;
            font-family: inherit;
            position: relative;
            padding-left: 20px;
        }
        .bonsai-info__template-item::before {
            content: "→";
            position: absolute;
            left: 0;
            color: #808080;
            font-weight: bold;
        }
        .bonsai-info__template-item--current::before {
            content: "✓";
            color: #4ec9b0;
        }
        .bonsai-info__template-item--missing::before {
            content: "✗";
            color: #f44747;
        }
        .bonsai-info__template-path {
            color: #d4d4d4;
        }
        .bonsai-info__template-path--current {
            color: #4ec9b0 !important;
            font-weight: bold;
            background: rgba(78, 201, 176, 0.1);
            padding: 2px 4px;
            border-radius: 3px;
        }
        .bonsai-info__template-path--missing {
            color: #808080;
            text-decoration: line-through;
        }
        .bonsai-info__template-path--site-specific {
            color: #9cdcfe;
        }
        .bonsai-info__note {
            font-size: 10px;
            color: #808080;
            font-style: italic;
            margin-top: 8px;
            padding: 6px 8px;
            background: rgba(128, 128, 128, 0.1);
            border-radius: 4px;
        }
        .bonsai-info__note code {
            background: rgba(206, 145, 120, 0.2);
            color: #ce9178;
            padding: 2px 4px;
            border-radius: 3px;
            font-family: inherit;
            font-size: 9px;
        }
        .bonsai-info__performance {
            border-top: 1px solid #454545;
            padding-top: 12px;
            margin-top: 12px;
        }
        .bonsai-info__performance-title {
            color: #569cd6;
            font-weight: 600;
            margin-bottom: 8px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .bonsai-info__performance-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
            margin-bottom: 8px;
        }
        .bonsai-info__performance-item {
            background: rgba(86, 156, 214, 0.1);
            padding: 6px 8px;
            border-radius: 4px;
            font-size: 11px;
        }
        .bonsai-info__performance-label {
            color: #9cdcfe;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 2px;
        }
        .bonsai-info__performance-value {
            color: #4ec9b0;
            font-weight: bold;
            font-size: 12px;
        }
        .bonsai-info__performance-value--warning {
            color: #ffcc02;
        }
        .bonsai-info__performance-value--error {
            color: #f44747;
        }
        .bonsai-info__fields {
            margin-bottom: 12px;
            padding: 8px;
            background: rgba(206, 145, 120, 0.1);
            border-radius: 4px;
            border-left: 3px solid #ce9178;
        }
        .bonsai-info__fields-label {
            color: #ce9178;
            font-weight: 600;
            margin-bottom: 8px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .bonsai-info__fields-count {
            background: rgba(206, 145, 120, 0.3);
            color: #ce9178;
            padding: 2px 6px;
            border-radius: 10px;
            font-size: 9px;
            font-weight: 500;
        }
        .bonsai-info__field-list {
            display: grid;
            grid-template-columns: 1fr;
            gap: 4px;
        }
        .bonsai-info__field-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 4px 6px;
            background: rgba(0, 0, 0, 0.2);
            border-radius: 3px;
            font-size: 11px;
        }
        .bonsai-info__field-handle {
            color: #dcdcaa;
            font-weight: 600;
            font-family: 'SF Mono', 'Monaco', 'Inconsolata', 'Roboto Mono', 'Consolas', 'Courier New', monospace;
            cursor: pointer;
            padding: 2px 4px;
            border-radius: 3px;
            transition: background 150ms ease;
        }
        .bonsai-info__field-handle:hover {
            background: rgba(220, 220, 170, 0.2);
        }
        .bonsai-info__field-type {
            color: #808080;
            font-size: 10px;
            font-style: italic;
        }
        .bonsai-info__field-name {
            color: #9cdcfe;
            font-size: 10px;
            margin-left: 6px;
            cursor: pointer;
            padding: 2px 4px;
            border-radius: 3px;
            transition: background 150ms ease;
            position: relative;
        }
        .bonsai-info__field-name:hover {
            background: rgba(156, 220, 254, 0.2);
            color: #bde0ff;
        }
        .bonsai-info__field-nested {
            margin-top: 6px;
            padding-left: 20px;
            border-left: 2px solid rgba(206, 145, 120, 0.3);
        }
        .bonsai-info__field-nested-toggle {
            cursor: pointer;
            color: #569cd6;
            font-size: 10px;
            margin-top: 4px;
            display: inline-block;
            user-select: none;
        }
        .bonsai-info__field-nested-toggle:hover {
            color: #9cdcfe;
        }
        .bonsai-info__field-nested-toggle::before {
            content: '▶ ';
            display: inline-block;
            transition: transform 150ms ease;
        }
        .bonsai-info__field-nested-toggle--expanded::before {
            transform: rotate(90deg);
        }
        .bonsai-info__field-nested-content {
            display: none;
            margin-top: 4px;
            padding: 6px 8px;
            background: rgba(0, 0, 0, 0.3);
            border-radius: 3px;
        }
        .bonsai-info__field-nested-content--visible {
            display: block;
        }
        .bonsai-info__field-block-type {
            margin-bottom: 8px;
            padding: 4px 0;
        }
        .bonsai-info__field-block-type:last-child {
            margin-bottom: 0;
        }
        .bonsai-info__field-block-type-name {
            color: #dcdcaa;
            font-weight: 600;
            font-size: 10px;
            margin-bottom: 4px;
        }
        .bonsai-info__field-block-type-handle {
            color: #808080;
            font-style: italic;
            font-size: 9px;
            cursor: pointer;
            padding: 2px 4px;
            border-radius: 3px;
            transition: background 150ms ease;
        }
        .bonsai-info__field-block-type-handle:hover {
            background: rgba(128, 128, 128, 0.2);
        }
        .bonsai-info__field-subfield {
            padding: 2px 0 2px 12px;
            font-size: 10px;
            display: flex;
            justify-content: space-between;
            border-left: 1px solid rgba(128, 128, 128, 0.3);
            margin-left: 4px;
        }
        .bonsai-info__field-subfield-handle {
            color: #ce9178;
            cursor: pointer;
            padding: 2px 4px;
            border-radius: 3px;
            transition: background 150ms ease;
        }
        .bonsai-info__field-subfield-handle:hover {
            background: rgba(206, 145, 120, 0.2);
        }
        .bonsai-info__field-subfield-type {
            color: #808080;
            font-size: 9px;
        }
        .bonsai-info__field-source {
            padding: 2px 0;
            font-size: 10px;
            color: #9cdcfe;
        }
        .bonsai-info__field-source-handle {
            color: #ce9178;
            font-family: 'SF Mono', 'Monaco', 'Inconsolata', 'Roboto Mono', 'Consolas', 'Courier New', monospace;
            cursor: pointer;
            padding: 2px 4px;
            border-radius: 3px;
            transition: background 150ms ease;
        }
        .bonsai-info__field-source-handle:hover {
            background: rgba(206, 145, 120, 0.2);
        }
        .bonsai-info__field-note {
            font-size: 10px;
            color: #808080;
            font-style: italic;
        }
        .bonsai-info__field-option {
            padding: 3px 0;
            font-size: 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .bonsai-info__field-option-label {
            color: #9cdcfe;
        }
        .bonsai-info__field-option-value {
            color: #ce9178;
            font-family: 'SF Mono', 'Monaco', 'Inconsolata', 'Roboto Mono', 'Consolas', 'Courier New', monospace;
            font-size: 9px;
        }
        .bonsai-info__field-option-default {
            color: #4ec9b0;
            font-size: 9px;
            margin-left: 6px;
            font-weight: bold;
        }
        .bonsai-info__tabs {
            display: flex;
            gap: 4px;
            margin-bottom: 12px;
            border-bottom: 2px solid #454545;
            padding-bottom: 0;
        }
        .bonsai-info__tab {
            padding: 6px 12px;
            cursor: pointer;
            background: transparent;
            border: none;
            color: #808080;
            font-family: inherit;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: color 150ms ease, background 150ms ease;
            border-radius: 4px 4px 0 0;
            position: relative;
        }
        .bonsai-info__tab:hover {
            color: #9cdcfe;
            background: rgba(86, 156, 214, 0.1);
        }
        .bonsai-info__tab--active {
            color: #569cd6;
            background: rgba(86, 156, 214, 0.15);
        }
        .bonsai-info__tab--active::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            right: 0;
            height: 2px;
            background: #569cd6;
        }
        .bonsai-info__tab-panel {
            display: none;
        }
        .bonsai-info__tab-panel--active {
            display: block;
        }
        .bonsai-info__copy-all-btn {
            background: rgba(78, 201, 176, 0.15);
            color: #4ec9b0;
            border: 1px solid rgba(78, 201, 176, 0.3);
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 10px;
            font-weight: 600;
            cursor: pointer;
            transition: all 150ms ease;
            font-family: inherit;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .bonsai-info__copy-all-btn:hover {
            background: rgba(78, 201, 176, 0.25);
            border-color: rgba(78, 201, 176, 0.5);
        }
        .bonsai-info__copy-all-btn:active {
            background: rgba(78, 201, 176, 0.35);
        }
        .bonsai-info__var-inputs {
            display: flex;
            gap: 8px;
            align-items: center;
            margin-bottom: 8px;
            font-size: 10px;
        }
        .bonsai-info__var-input-group {
            display: flex;
            align-items: center;
            gap: 4px;
        }
        .bonsai-info__var-label {
            color: #808080;
            font-size: 9px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .bonsai-info__var-input {
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(206, 145, 120, 0.3);
            color: #dcdcaa;
            padding: 2px 6px;
            border-radius: 3px;
            font-size: 10px;
            font-family: 'SF Mono', 'Monaco', 'Inconsolata', 'Roboto Mono', 'Consolas', 'Courier New', monospace;
            width: 60px;
        }
        .bonsai-info__var-input:focus {
            outline: none;
            border-color: rgba(206, 145, 120, 0.6);
            background: rgba(0, 0, 0, 0.4);
        }
    </style>
{% endapply %}
<div class="bonsai-info__hover">
    <div class="bonsai-info__text">
        <div class="bonsai-info__header">
            <div class="bonsai-info__header-top">
                {% set displayHandle = data.element_info.section_handle ?? data.element_info.handle ?? data.type|default('template') %}
                <div class="bonsai-info__title bonsai-info__copyable" data-copy-text="{{ displayHandle }}" title="Click to copy handle">
                    {{ displayHandle }}
                </div>
                <div class="bonsai-info__type-badge">{{ data.type|default('template') }}</div>
                {% if data.strategy is defined and data.strategy != 'section' %}
                    <div class="bonsai-info__type-badge bonsai-info__type-badge--strategy">{{ data.strategy }}</div>
                {% endif %}
            </div>
        </div>

        <div class="bonsai-info__tabs">
            <button class="bonsai-info__tab" data-tab="templates">Templates</button>
            {% if data.field_handles is defined and data.field_handles is not null %}
                <button class="bonsai-info__tab" data-tab="fields">Fields</button>
            {% endif %}
            <button class="bonsai-info__tab" data-tab="context">Context</button>
        </div>

        <div class="bonsai-info__tab-panel" data-panel="templates">
            <div class="bonsai-info__templates">
                <div class="bonsai-info__templates-label">
                    Template Resolution Hierarchy
                    <span class="bonsai-info__template-count">{{ data.templates|length }} paths</span>
                </div>

                <div class="bonsai-info__template-hierarchy">
                    {% set originalTemplates = data.templates %}
                    {% set optimizedTemplates = data.optimized_templates|default([]) %}
                    {% set currentTemplate = data.currentTemplate %}

                    {% if optimizedTemplates|length > 0 and optimizedTemplates != originalTemplates %}
                        <div class="bonsai-info__template-group">
                            <div class="bonsai-info__template-group-label">Original Templates ({{ originalTemplates|length }})</div>
                            <div class="bonsai-info__template-list">
                                {% for template in originalTemplates %}
                                    <div class="bonsai-info__template-item {% if template == currentTemplate %}bonsai-info__template-item--current{% else %}bonsai-info__template-item--missing{% endif %}">
                                        <span class="bonsai-info__template-path {% if template == currentTemplate %}bonsai-info__template-path--current{% else %}bonsai-info__template-path--missing{% endif %}">
                                            {{ template }}
                                        </span>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>

                        <div class="bonsai-info__template-group">
                            <div class="bonsai-info__template-group-label">Optimized Templates ({{ optimizedTemplates|length }})</div>
                            <div class="bonsai-info__template-list">
                                {% for template in optimizedTemplates %}
                                    {% set isSiteSpecific = template matches '/_(\\w+)/' or template matches '/(\\w+)/' %}
                                    <div class="bonsai-info__template-item {% if template == currentTemplate %}bonsai-info__template-item--current{% else %}bonsai-info__template-item--missing{% endif %}">
                                        <span class="bonsai-info__template-path {% if template == currentTemplate %}bonsai-info__template-path--current{% elseif isSiteSpecific %}bonsai-info__template-path--site-specific{% else %}bonsai-info__template-path--missing{% endif %}">
                                            {{ template }}
                                        </span>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    {% else %}
                        <div class="bonsai-info__template-group">
                            <div class="bonsai-info__template-group-label">Template Paths ({{ originalTemplates|length }})</div>
                            <div class="bonsai-info__template-list">
                                {% for template in originalTemplates %}
                                    {% set isSiteSpecific = template matches '/_(\\w+)/' or template matches '/(\\w+)/' %}
                                    <div class="bonsai-info__template-item {% if template == currentTemplate %}bonsai-info__template-item--current{% else %}bonsai-info__template-item--missing{% endif %}">
                                        <span class="bonsai-info__template-path {% if template == currentTemplate %}bonsai-info__template-path--current{% elseif isSiteSpecific %}bonsai-info__template-path--site-specific{% else %}bonsai-info__template-path--missing{% endif %}">
                                            {{ template }}
                                        </span>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}
                </div>

                <div class="bonsai-info__note">
                    Templates are checked in priority order. ✓ = found, ✗ = missing, blue = site-specific
                </div>
            </div>
        </div>

        {% if data.field_handles is defined and data.field_handles is not null %}
            <div class="bonsai-info__tab-panel" data-panel="fields" data-element-type="{{ data.type|default('template') }}">
                <div class="bonsai-info__fields">
                    <div class="bonsai-info__var-inputs">
                        <div class="bonsai-info__var-input-group">
                            <label class="bonsai-info__var-label">Element:</label>
                            <input type="text" class="bonsai-info__var-input" id="bonsai-element-var" placeholder="entry" value="entry">
                        </div>
                        <div class="bonsai-info__var-input-group">
                            <label class="bonsai-info__var-label">Loop:</label>
                            <input type="text" class="bonsai-info__var-input" id="bonsai-loop-var" placeholder="item" value="item">
                        </div>
                    </div>
                    <div class="bonsai-info__fields-label">
                        Available Field Handles
                        <div style="display: flex; gap: 8px; align-items: center;">
                            <span class="bonsai-info__fields-count">{{ data.field_handles|length }} fields</span>
                            <button class="bonsai-info__copy-all-btn" data-copy-all="fields" title="Copy all fields with Twig tags (for loops for relational fields, output tags for others)">
                                📋 Copy All
                            </button>
                        </div>
                    </div>
                    <div class="bonsai-info__field-list">
                        {% for field in data.field_handles %}
                            <div class="bonsai-info__field-item">
                                <div style="width: 100%;">
                                    <div style="display: flex; justify-content: space-between; align-items: center;">
                                        <div>
                                            <span class="bonsai-info__field-handle" data-field-handle="{{ field.handle }}" data-field-type="{{ field.type }}" title="Click to copy Twig formatted">{{ field.handle }}</span>
                                            <span class="bonsai-info__field-name" data-copy-text="{{ field.handle }}" title="Click to copy handle">({{ field.name }})</span>
                                        </div>
                                        <span class="bonsai-info__field-type">{{ field.type }}</span>
                                    </div>

                                    {% if field.nested is defined %}
                                        <div class="bonsai-info__field-nested">
                                            <span class="bonsai-info__field-nested-toggle" data-toggle="nested-{{ loop.index }}">
                                                {% if field.nested.type == 'matrix' %}
                                                    Show {{ field.nested.blocks|length }} block types
                                                {% elseif field.nested.type == 'entries' %}
                                                    Show allowed sections
                                                {% elseif field.nested.type == 'categories' %}
                                                    Show allowed groups
                                                {% elseif field.nested.type == 'assets' %}
                                                    Show allowed volumes
                                                {% elseif field.nested.type == 'users' %}
                                                    User elements
                                                {% elseif field.nested.type == 'dropdown' %}
                                                    {% set optionCount = field.nested.options is defined ? field.nested.options|length : 0 %}
                                                    Show {{ optionCount }} dropdown options
                                                {% elseif field.nested.type == 'radio' %}
                                                    {% set optionCount = field.nested.options is defined ? field.nested.options|length : 0 %}
                                                    Show {{ optionCount }} radio options
                                                {% elseif field.nested.type == 'checkboxes' %}
                                                    {% set optionCount = field.nested.options is defined ? field.nested.options|length : 0 %}
                                                    Show {{ optionCount }} checkbox options
                                                {% elseif field.nested.type == 'multiselect' %}
                                                    {% set optionCount = field.nested.options is defined ? field.nested.options|length : 0 %}
                                                    Show {{ optionCount }} select options
                                                {% elseif field.nested.type == 'lightswitch' %}
                                                    Boolean field
                                                {% endif %}
                                            </span>

                                            <div class="bonsai-info__field-nested-content" data-content="nested-{{ loop.index }}">
                                                {% if field.nested.type == 'matrix' and field.nested.blocks is defined %}
                                                    {% for block in field.nested.blocks %}
                                                        <div class="bonsai-info__field-block-type">
                                                            <div class="bonsai-info__field-block-type-name">
                                                                {{ block.name }}
                                                                <span class="bonsai-info__field-block-type-handle" data-copy-text="{{ block.handle }}" title="Click to copy">({{ block.handle }})</span>
                                                            </div>
                                                            {% for subfield in block.fields %}
                                                                <div class="bonsai-info__field-subfield">
                                                                    <span class="bonsai-info__field-subfield-handle" data-copy-text="{{ subfield.handle }}" title="Click to copy">{{ subfield.handle }}</span>
                                                                    <span class="bonsai-info__field-subfield-type">{{ subfield.type }}</span>
                                                                </div>
                                                            {% endfor %}
                                                        </div>
                                                    {% endfor %}
                                                {% elseif field.nested.sources is defined %}
                                                    {% for source in field.nested.sources %}
                                                        <div class="bonsai-info__field-source">
                                                            <span class="bonsai-info__field-source-handle" data-copy-text="{{ source.handle }}" title="Click to copy">{{ source.handle }}</span>
                                                            <span class="bonsai-info__field-name"> ({{ source.name }})</span>
                                                        </div>
                                                    {% endfor %}
                                                {% elseif field.nested.options is defined %}
                                                    {% for option in field.nested.options %}
                                                        <div class="bonsai-info__field-option">
                                                            <span class="bonsai-info__field-option-label">
                                                                {{ option.label }}
                                                                {% if option.isDefault is defined and option.isDefault %}
                                                                    <span class="bonsai-info__field-option-default">(default)</span>
                                                                {% endif %}
                                                            </span>
                                                            <span class="bonsai-info__field-option-value">{{ option.value }}</span>
                                                        </div>
                                                    {% endfor %}
                                                {% elseif field.nested.note is defined %}
                                                    <div class="bonsai-info__field-note">{{ field.nested.note }}</div>
                                                {% endif %}
                                            </div>
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        {% endif %}

        <div class="bonsai-info__tab-panel" data-panel="context">
            <div class="bonsai-info__directory">
                <div class="bonsai-info__directory-label">Template Directory</div>
                <div class="bonsai-info__directory-path">{{ data.directory }}</div>
            </div>

            {% if data.site_info is defined %}
                <div class="bonsai-info__site-context">
                    <div class="bonsai-info__site-label">Site Context</div>
                    {% if data.site_info.current_site %}
                        <div class="bonsai-info__site-item">
                            <span class="bonsai-info__site-key">Current Site:</span>
                            <span class="bonsai-info__site-value">{{ data.site_info.current_site }}</span>
                        </div>
                    {% endif %}
                    {% if data.site_info.element_site %}
                        <div class="bonsai-info__site-item">
                            <span class="bonsai-info__site-key">Element Site:</span>
                            <span class="bonsai-info__site-value">{{ data.site_info.element_site }}</span>
                        </div>
                    {% endif %}
                    {% if data.site_info.base_site %}
                        <div class="bonsai-info__site-item">
                            <span class="bonsai-info__site-key">Base Site:</span>
                            <span class="bonsai-info__site-value">{{ data.site_info.base_site }}</span>
                        </div>
                    {% endif %}
                    {% if data.site_info.fallback_site %}
                        <div class="bonsai-info__site-item">
                            <span class="bonsai-info__site-key">Fallback Site:</span>
                            <span class="bonsai-info__site-value">{{ data.site_info.fallback_site }}</span>
                        </div>
                    {% endif %}
                </div>
            {% endif %}

            {% if data.performance is defined %}
                <div class="bonsai-info__performance">
                    <div class="bonsai-info__performance-title">{{ 'Resource Usage'|t('bonsai-twig') }}</div>

                    <div class="bonsai-info__performance-grid">
                        <div class="bonsai-info__performance-item">
                            <div class="bonsai-info__performance-label">Resolution Time</div>
                            <div class="bonsai-info__performance-value {% if data.performance.resolution_time > 0.1 %}bonsai-info__performance-value--warning{% elseif data.performance.resolution_time > 0.5 %}bonsai-info__performance-value--error{% endif %}">
                                {% if data.performance.resolution_time < 0.001 %}
                                    {{ (data.performance.resolution_time * 1000000)|round(2) }}μs
                                {% elseif data.performance.resolution_time < 1 %}
                                    {{ (data.performance.resolution_time * 1000)|round(2) }}ms
                                {% else %}
                                    {{ data.performance.resolution_time|round(3) }}s
                                {% endif %}
                            </div>
                        </div>

                        {% if data.performance.memory_usage is defined and data.performance.memory_usage.delta is defined %}
                            <div class="bonsai-info__performance-item">
                                <div class="bonsai-info__performance-label">Memory Delta</div>
                                <div class="bonsai-info__performance-value {% if data.performance.memory_usage.delta > 1048576 %}bonsai-info__performance-value--warning{% elseif data.performance.memory_usage.delta > 5242880 %}bonsai-info__performance-value--error{% endif %}">
                                    {% set memDelta = data.performance.memory_usage.delta %}
                                    {% if memDelta < 1024 %}
                                        {{ memDelta }}B
                                    {% elseif memDelta < 1048576 %}
                                        {{ (memDelta / 1024)|round(2) }}KB
                                    {% else %}
                                        {{ (memDelta / 1048576)|round(2) }}MB
                                    {% endif %}
                                </div>
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% endif %}

        </div>

        <div style="text-align: right; padding-top: 6px;">
            <a href="#" class="bonsai-info__close" style="color: #555; font-size: 11px; text-decoration: none; opacity: 0.6; transition: opacity 0.15s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.6'" onclick="event.preventDefault(); var u = new URL(window.location); u.searchParams.delete('beastmode'); window.location = u.toString();">&#x2715; close beastmode</a>
        </div>

        <script>
            {% verbatim %}
            (function() {
                const STORAGE_KEY = 'bonsai-twig-active-tab';
                const infoText = document.currentScript.closest('.bonsai-info__text');
                const tabs = infoText.querySelectorAll('.bonsai-info__tab');
                const panels = infoText.querySelectorAll('.bonsai-info__tab-panel');

                // Tab switching functionality
                function activateTab(tabName) {
                    tabs.forEach(tab => {
                        if (tab.dataset.tab === tabName) {
                            tab.classList.add('bonsai-info__tab--active');
                        } else {
                            tab.classList.remove('bonsai-info__tab--active');
                        }
                    });

                    panels.forEach(panel => {
                        if (panel.dataset.panel === tabName) {
                            panel.classList.add('bonsai-info__tab-panel--active');
                        } else {
                            panel.classList.remove('bonsai-info__tab-panel--active');
                        }
                    });

                    try {
                        localStorage.setItem(STORAGE_KEY, tabName);
                    } catch (e) {
                        // localStorage might be disabled
                    }
                }

                tabs.forEach(tab => {
                    tab.addEventListener('click', function() {
                        activateTab(this.dataset.tab);
                    });
                });

                // Restore last active tab or default to first tab
                let activeTab = 'templates';
                try {
                    const stored = localStorage.getItem(STORAGE_KEY);
                    if (stored) {
                        // Check if the stored tab exists in this infobar
                        const tabExists = Array.from(tabs).some(tab => tab.dataset.tab === stored);
                        if (tabExists) {
                            activeTab = stored;
                        }
                    }
                } catch (e) {
                    // localStorage might be disabled
                }

                activateTab(activeTab);

                // Variable name inputs with localStorage persistence (per element type)
                const elementVarInput = infoText.querySelector('#bonsai-element-var');
                const loopVarInput = infoText.querySelector('#bonsai-loop-var');
                const fieldsPanel = infoText.querySelector('[data-panel="fields"]');

                if (elementVarInput && loopVarInput && fieldsPanel) {
                    // Get element type for context-specific storage
                    const elementType = fieldsPanel.dataset.elementType || 'template';

                    // Smart defaults based on element type
                    const defaults = {
                        'entry': { element: 'entry', loop: 'item' },
                        'category': { element: 'category', loop: 'item' },
                        'matrix': { element: 'block', loop: 'item' },
                        'asset': { element: 'asset', loop: 'item' },
                        'user': { element: 'user', loop: 'item' },
                        'product': { element: 'product', loop: 'item' },
                        'template': { element: 'entry', loop: 'item' }
                    };

                    const defaultVars = defaults[elementType] || defaults['template'];

                    // Load saved values or set smart defaults
                    try {
                        const savedElementVar = localStorage.getItem(`bonsai-twig-element-var-${elementType}`);
                        const savedLoopVar = localStorage.getItem(`bonsai-twig-loop-var-${elementType}`);

                        elementVarInput.value = savedElementVar || defaultVars.element;
                        loopVarInput.value = savedLoopVar || defaultVars.loop;
                    } catch (e) {
                        // localStorage might be disabled
                        elementVarInput.value = defaultVars.element;
                        loopVarInput.value = defaultVars.loop;
                    }

                    // Save to localStorage on change (type-specific)
                    elementVarInput.addEventListener('input', function() {
                        try {
                            localStorage.setItem(`bonsai-twig-element-var-${elementType}`, this.value);
                        } catch (e) {
                            // localStorage might be disabled
                        }
                    });

                    loopVarInput.addEventListener('input', function() {
                        try {
                            localStorage.setItem(`bonsai-twig-loop-var-${elementType}`, this.value);
                        } catch (e) {
                            // localStorage might be disabled
                        }
                    });
                }

                // Nested field expand/collapse functionality
                const nestedToggles = infoText.querySelectorAll('.bonsai-info__field-nested-toggle');
                nestedToggles.forEach(toggle => {
                    toggle.addEventListener('click', function() {
                        const targetId = this.dataset.toggle;
                        const content = infoText.querySelector('[data-content="' + targetId + '"]');

                        if (content) {
                            const isExpanded = content.classList.contains('bonsai-info__field-nested-content--visible');

                            if (isExpanded) {
                                content.classList.remove('bonsai-info__field-nested-content--visible');
                                this.classList.remove('bonsai-info__field-nested-toggle--expanded');
                            } else {
                                content.classList.add('bonsai-info__field-nested-content--visible');
                                this.classList.add('bonsai-info__field-nested-toggle--expanded');
                            }
                        }
                    });
                });

                // Click to copy functionality
                const copyableElements = infoText.querySelectorAll('[data-copy-text]');
                copyableElements.forEach(element => {
                    element.addEventListener('click', function(e) {
                        e.stopPropagation();
                        const textToCopy = this.dataset.copyText;

                        // Use modern clipboard API if available
                        if (navigator.clipboard && navigator.clipboard.writeText) {
                            navigator.clipboard.writeText(textToCopy).then(() => {
                                showCopyFeedback(this);
                            }).catch(err => {
                                console.warn('Failed to copy text:', err);
                                fallbackCopyText(textToCopy, this);
                            });
                        } else {
                            fallbackCopyText(textToCopy, this);
                        }
                    });
                });

                // Helper function to generate Twig code based on field type
                function generateTwigCode(handle, type, elementVar, loopVar) {
                    let suffix = '';
                    let twigCode = '';

                    if (type.includes('Asset')) {
                        suffix = '.all()';
                        twigCode = `{% for ${loopVar} in ${elementVar}.${handle}${suffix} %}\n{% endfor %}`;
                    } else if (type.includes('Entries') || type.includes('Categories') ||
                              type.includes('Users') || type.includes('Tags')) {
                        suffix = '.all()';
                        twigCode = `{% for ${loopVar} in ${elementVar}.${handle}${suffix} %}\n{% endfor %}`;
                    } else if (type.includes('Matrix') || type.includes('Table')) {
                        suffix = '.all()';
                        twigCode = `{% for ${loopVar} in ${elementVar}.${handle}${suffix} %}\n{% endfor %}`;
                    } else {
                        // Plain field, just wrap in output tags
                        twigCode = `{{ ${elementVar}.${handle} }}`;
                    }

                    return twigCode;
                }

                // Helper function to copy text to clipboard
                function copyToClipboard(text, element, feedbackText) {
                    if (navigator.clipboard && navigator.clipboard.writeText) {
                        navigator.clipboard.writeText(text).then(() => {
                            showCopyFeedback(element, feedbackText);
                        }).catch(err => {
                            console.warn('Failed to copy:', err);
                            fallbackCopyText(text, element, feedbackText);
                        });
                    } else {
                        fallbackCopyText(text, element, feedbackText);
                    }
                }

                // Click to copy Twig-formatted field handles
                const fieldHandles = infoText.querySelectorAll('.bonsai-info__field-handle[data-field-handle]');
                fieldHandles.forEach(element => {
                    element.addEventListener('click', function(e) {
                        e.stopPropagation();

                        const handle = this.dataset.fieldHandle;
                        const type = this.dataset.fieldType;
                        const elementVar = elementVarInput.value.trim() || 'entry';
                        const loopVar = loopVarInput.value.trim() || 'item';

                        const twigCode = generateTwigCode(handle, type, elementVar, loopVar);
                        copyToClipboard(twigCode, this, 'Twig copied!');
                    });
                });

                // Copy all fields functionality
                const copyAllBtn = infoText.querySelector('[data-copy-all="fields"]');
                if (copyAllBtn) {
                    copyAllBtn.addEventListener('click', function(e) {
                        e.stopPropagation();

                        const elementVar = elementVarInput.value.trim() || 'entry';
                        const loopVar = loopVarInput.value.trim() || 'item';
                        const fields = [];

                        // Gather all field handles from the DOM
                        infoText.querySelectorAll('.bonsai-info__field-item').forEach(fieldItem => {
                            const handleEl = fieldItem.querySelector('.bonsai-info__field-handle');
                            const typeEl = fieldItem.querySelector('.bonsai-info__field-type');

                            if (handleEl && handleEl.dataset.fieldHandle) {
                                const handle = handleEl.dataset.fieldHandle;
                                const type = typeEl ? typeEl.textContent.trim() : '';
                                const twigCode = generateTwigCode(handle, type, elementVar, loopVar);
                                fields.push(twigCode);
                            }
                        });

                        const textToCopy = fields.join('\n');
                        const feedbackText = `${fields.length} fields copied!`;
                        copyToClipboard(textToCopy, this, feedbackText);
                    });
                }

                // Show visual feedback when text is copied
                function showCopyFeedback(element, customText) {
                    // Create tooltip if it doesn't exist
                    let tooltip = element.querySelector('.bonsai-info__copy-tooltip');
                    if (!tooltip) {
                        tooltip = document.createElement('span');
                        tooltip.className = 'bonsai-info__copy-tooltip';
                        element.style.position = 'relative';
                        element.appendChild(tooltip);
                    }

                    tooltip.textContent = customText || 'Copied!';

                    // Show tooltip
                    tooltip.classList.add('bonsai-info__copy-tooltip--visible');

                    // Hide after appropriate duration
                    const duration = customText ? 1500 : 1000;
                    setTimeout(() => {
                        tooltip.classList.remove('bonsai-info__copy-tooltip--visible');
                    }, duration);
                }

                // Fallback for older browsers
                function fallbackCopyText(text, element, customText) {
                    const textArea = document.createElement('textarea');
                    textArea.value = text;
                    textArea.style.position = 'fixed';
                    textArea.style.left = '-999999px';
                    textArea.style.top = '-999999px';
                    document.body.appendChild(textArea);
                    textArea.focus();
                    textArea.select();

                    try {
                        document.execCommand('copy');
                        showCopyFeedback(element, customText);
                    } catch (err) {
                        console.warn('Failed to copy text:', err);
                    }

                    document.body.removeChild(textArea);
                }
            })();
            {% endverbatim %}
        </script>
    </div>
    {{ content|raw }}
</div>
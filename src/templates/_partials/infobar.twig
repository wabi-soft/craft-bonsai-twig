{% set data = info|json_decode %}

{% apply spaceless %}
    <style>
        .bonsai-info__hover {
            position: relative;
        }
        .bonsai-info__hover:hover .bonsai-info__text {
            opacity: 1 !important;
            transition: opacity 150ms;
        }
        .bonsai-info__text {
            position: absolute;
            top: 0;
            left: 0;
            background: #1e1e1e;
            color: #d4d4d4;
            font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
            font-size: 12px;
            padding: 12px;
            z-index: 1000;
            max-width: 100%;
            overflow-x: auto;
            opacity: 0;
            border: 1px solid #454545;
            border-radius: 4px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.15);
            line-height: 1.4;
        }
        .bonsai-info__directory {
            border-bottom: 1px solid #454545;
            padding-bottom: 8px;
            margin-bottom: 8px;
        }
        .bonsai-info__directory strong {
            color: #569cd6;
        }
        .bonsai-info__templates {
            margin-top: 4px;
            margin-bottom: 4px;
            font-weight: bold;
            color: #569cd6;
        }
        .bonsai-info__template-list {
            padding-left: 24px;
            margin: 12px 0;
            list-style: decimal;
        }
        .bonsai-info__template-item {
            padding: 0;
            line-height: 1.3;
            margin-bottom: 4px;
            font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
        }
        span.bonsai-info__template--current {
            color: #3ddab5 !important;
            font-weight: bold;
        }
        .bonsai-info__note {
            font-size: 11px;
            color: #808080;
            font-style: italic;
            margin-top: 4px;
        }
        .bonsai-info__performance {
            border-top: 1px solid #454545;
            padding-top: 8px;
            margin-top: 8px;
        }
        .bonsai-info__performance-title {
            color: #569cd6;
            font-weight: bold;
            margin-bottom: 4px;
        }
        .bonsai-info__performance-item {
            margin: 2px 0;
            font-size: 11px;
        }
        .bonsai-info__performance-value {
            color: #3ddab5;
        }
        .bonsai-info__cache-stats {
            border-top: 1px solid #454545;
            padding-top: 8px;
            margin-top: 8px;
        }
        .bonsai-info__cache-title {
            color: #569cd6;
            font-weight: bold;
            margin-bottom: 4px;
        }
        .bonsai-info__cache-item {
            margin: 2px 0;
            font-size: 11px;
        }
    </style>
{% endapply %}
<div class="bonsai-info__hover">
    <div class="bonsai-info__text">
        <div class="bonsai-info__directory"><strong>Directory:</strong> {{ data.directory }}</div>
        <div class="bonsai-info__templates">Templates{% if data.templates|length > 1 %} (Most → Least Specific){% endif %}:</div>
        {% if data.templates|length > 1 %}
            <ol class="bonsai-info__template-list">
                {% for template in data.templates %}
                    <li class="bonsai-info__template-item">
                        <span {% if template == data.currentTemplate %}class="bonsai-info__template--current"{% endif %}>
                            {{ template }}{% if template == data.currentTemplate %} ← current{% endif %}
                        </span>
                    </li>
                {% endfor %}
            </ol>
            <div class="bonsai-info__note">Templates are checked in order until a match is found</div>
        {% else %}
            <div class="bonsai-info__template-list">
                {% for template in data.templates %}
                    <div class="bonsai-info__template-item">
                        <span {% if template == data.currentTemplate %}class="bonsai-info__template--current"{% endif %}>
                            {{ template }}{% if template == data.currentTemplate %} ← current{% endif %}
                        </span>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
        
        {% if data.performance is defined %}
            <div class="bonsai-info__performance">
                <div class="bonsai-info__performance-title">Performance Metrics:</div>
                <div class="bonsai-info__performance-item">
                    Resolution Time: <span class="bonsai-info__performance-value">
                        {% if data.performance.resolution_time < 0.001 %}
                            {{ (data.performance.resolution_time * 1000000)|round(2) }}μs
                        {% elseif data.performance.resolution_time < 1 %}
                            {{ (data.performance.resolution_time * 1000)|round(2) }}ms
                        {% else %}
                            {{ data.performance.resolution_time|round(3) }}s
                        {% endif %}
                    </span>
                </div>
                {% if data.performance.memory_usage is defined %}
                    <div class="bonsai-info__performance-item">
                        Memory Delta: <span class="bonsai-info__performance-value">
                            {% set memDelta = data.performance.memory_usage.delta %}
                            {% if memDelta < 1024 %}
                                {{ memDelta }}B
                            {% elseif memDelta < 1048576 %}
                                {{ (memDelta / 1024)|round(2) }}KB
                            {% else %}
                                {{ (memDelta / 1048576)|round(2) }}MB
                            {% endif %}
                        </span>
                    </div>
                {% endif %}
                {% if data.performance.checkpoints is defined and data.performance.checkpoints|length > 0 %}
                    <div class="bonsai-info__performance-item">
                        Checkpoints: 
                        {% for checkpoint, checkpointData in data.performance.checkpoints %}
                            <div style="margin-left: 12px; font-size: 10px;">
                                {{ checkpoint }}: <span class="bonsai-info__performance-value">
                                    {% if checkpointData.elapsed < 0.001 %}
                                        {{ (checkpointData.elapsed * 1000000)|round(2) }}μs
                                    {% elseif checkpointData.elapsed < 1 %}
                                        {{ (checkpointData.elapsed * 1000)|round(2) }}ms
                                    {% else %}
                                        {{ checkpointData.elapsed|round(3) }}s
                                    {% endif %}
                                </span>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        {% endif %}
        
        {% if data.cache_stats is defined %}
            <div class="bonsai-info__cache-stats">
                <div class="bonsai-info__cache-title">Cache Statistics:</div>
                <div class="bonsai-info__cache-item">
                    Hit Rate: <span class="bonsai-info__performance-value">{{ data.cache_stats.hit_rate }}%</span>
                </div>
                <div class="bonsai-info__cache-item">
                    Total Requests: <span class="bonsai-info__performance-value">{{ data.cache_stats.total_requests }}</span>
                </div>
                {% if data.cache_stats.by_type is defined and data.cache_stats.by_type|length > 0 %}
                    <div class="bonsai-info__cache-item">
                        By Type:
                        {% for cacheType, typeStats in data.cache_stats.by_type %}
                            <div style="margin-left: 12px; font-size: 10px;">
                                {{ cacheType }}: <span class="bonsai-info__performance-value">{{ typeStats.hit_rate }}%</span> 
                                ({{ typeStats.hits }}/{{ typeStats.total }})
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        {% endif %}
    </div>
    {{ content|raw }}
</div>
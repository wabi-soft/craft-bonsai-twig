{% set data = info|json_decode %}
<style>
    .bonsai-info__hover {
        position: relative;
    }
    .bonsai-info__hover:hover .bonsai-info__text {
        opacity: 1 !important;
        transition: opacity 150ms;
    }
    .bonsai-info__text {
        position: absolute;
        top: 0;
        left: 0;
        background: rgba(0,0,0,0.8);
        color: white;
        font-family: monospace;
        font-size: 12px;
        padding: 8px;
        z-index: 1000;
        max-width: 100%;
        overflow-x: auto;
        opacity: 0;
    }
    .bonsai-info__templates {
        margin-top: 4px;
    }
    .bonsai-info__template-list {
        padding-left: 8px;
    }
    .bonsai-info__template--current {
        color: #00ff00;
        font-weight: bold;
    }
</style>
<div class="bonsai-info__hover">
<div class="bonsai-info__text">
    <div>Directory: {{ data.directory }}</div>
    <div class="bonsai-info__templates">Templates:</div>
    <div class="bonsai-info__template-list">
        {% for template in data.templates %}
            {% set fullPath = data.directory ~ '/' ~ template %}
            <div {% if fullPath == data.currentTemplate %}class="bonsai-info__template--current"{% endif %}>
                {{ template }}{% if fullPath == data.currentTemplate %} ← current{% endif %}
            </div>
        {% endfor %}
    </div>
</div>
{{ content|raw }}
</div>
{% set data = info|json_decode %}

{% apply spaceless %}
    <style>
        .bonsai-info__hover {
            position: relative;
        }
        .bonsai-info__hover:hover .bonsai-info__text {
            opacity: 1 !important;
            transition: opacity 150ms;
        }
        .bonsai-info__text {
            position: absolute;
            top: 0;
            left: 0;
            background: #1e1e1e;
            color: #d4d4d4;
            font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
            font-size: 12px;
            padding: 12px;
            z-index: 1000;
            max-width: 100%;
            overflow-x: auto;
            opacity: 0;
            border: 1px solid #454545;
            border-radius: 4px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.15);
            line-height: 1.4;
        }
        .bonsai-info__directory {
            border-bottom: 1px solid #454545;
            padding-bottom: 8px;
            margin-bottom: 8px;
        }
        .bonsai-info__directory strong {
            color: #569cd6;
        }
        .bonsai-info__templates {
            margin-top: 4px;
            margin-bottom: 4px;
            font-weight: bold;
            color: #569cd6;
        }
        .bonsai-info__template-list {
            padding-left: 24px;
            margin: 12px 0;
            list-style: decimal;
        }
        .bonsai-info__template-item {
            padding: 0;
            line-height: 1.3;
            margin-bottom: 4px;
            font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
        }
        span.bonsai-info__template--current {
            color: #3ddab5 !important;
            font-weight: bold;
        }
        .bonsai-info__note {
            font-size: 11px;
            color: #808080;
            font-style: italic;
            margin-top: 4px;
        }
    </style>
{% endapply %}
<div class="bonsai-info__hover">
    <div class="bonsai-info__text">
        <div class="bonsai-info__directory"><strong>Directory:</strong> {{ data.directory }}</div>
        <div class="bonsai-info__templates">Templates{% if data.templates|length > 1 %} (Most → Least Specific){% endif %}:</div>
        {% if data.templates|length > 1 %}
            <ol class="bonsai-info__template-list">
                {% for template in data.templates %}
                    <li class="bonsai-info__template-item">
                        <span {% if template == data.currentTemplate %}class="bonsai-info__template--current"{% endif %}>
                            {{ template }}{% if template == data.currentTemplate %} ← current{% endif %}
                        </span>
                    </li>
                {% endfor %}
            </ol>
            <div class="bonsai-info__note">Templates are checked in order until a match is found</div>
        {% else %}
            <div class="bonsai-info__template-list">
                {% for template in data.templates %}
                    <div class="bonsai-info__template-item">
                        <span {% if template == data.currentTemplate %}class="bonsai-info__template--current"{% endif %}>
                            {{ template }}{% if template == data.currentTemplate %} ← current{% endif %}
                        </span>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
    {{ content|raw }}
</div>
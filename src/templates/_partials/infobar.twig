{% set data = info|json_decode %}

{% apply spaceless %}
    <style>
        .bonsai-info__hover {
            position: relative;
            display: inline-block;
        }
        .bonsai-info__hover:hover .bonsai-info__text {
            opacity: 1 !important;
            visibility: visible !important;
            transition: opacity 200ms ease-in-out, visibility 0ms;
        }
        .bonsai-info__text {
            position: absolute;
            top: 0;
            left: 0;
            background: #1e1e1e;
            color: #d4d4d4;
            font-family: 'SF Mono', 'Monaco', 'Inconsolata', 'Roboto Mono', 'Consolas', 'Courier New', monospace;
            font-size: 12px;
            padding: 16px;
            z-index: 10000;
            min-width: 400px;
            max-width: 600px;
            overflow-x: auto;
            opacity: 0;
            visibility: hidden;
            border: 1px solid #454545;
            border-radius: 6px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3), 0 0 0 1px rgba(255,255,255,0.1);
            line-height: 1.5;
            transition: opacity 200ms ease-in-out, visibility 200ms ease-in-out;
            backdrop-filter: blur(10px);
        }
        .bonsai-info__header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 1px solid #454545;
            padding-bottom: 12px;
            margin-bottom: 12px;
        }
        .bonsai-info__title {
            color: #569cd6;
            font-weight: bold;
            font-size: 13px;
        }
        .bonsai-info__type-badge {
            background: #264f78;
            color: #9cdcfe;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 10px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .bonsai-info__directory {
            margin-bottom: 12px;
        }
        .bonsai-info__directory-label {
            color: #569cd6;
            font-weight: 600;
            margin-bottom: 4px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .bonsai-info__directory-path {
            color: #ce9178;
            font-weight: 500;
            background: rgba(206, 145, 120, 0.1);
            padding: 4px 8px;
            border-radius: 4px;
            border-left: 3px solid #ce9178;
        }
        .bonsai-info__site-context {
            margin-bottom: 12px;
            padding: 8px;
            background: rgba(86, 156, 214, 0.1);
            border-radius: 4px;
            border-left: 3px solid #569cd6;
        }
        .bonsai-info__site-label {
            color: #569cd6;
            font-weight: 600;
            margin-bottom: 4px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .bonsai-info__site-item {
            margin: 2px 0;
            font-size: 11px;
            display: flex;
            justify-content: space-between;
        }
        .bonsai-info__site-key {
            color: #9cdcfe;
        }
        .bonsai-info__site-value {
            color: #ce9178;
            font-weight: 500;
        }
        .bonsai-info__templates {
            margin-bottom: 12px;
        }
        .bonsai-info__templates-label {
            color: #569cd6;
            font-weight: 600;
            margin-bottom: 8px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .bonsai-info__template-count {
            background: #264f78;
            color: #9cdcfe;
            padding: 2px 6px;
            border-radius: 10px;
            font-size: 9px;
            font-weight: 500;
        }
        .bonsai-info__template-hierarchy {
            margin: 8px 0;
        }
        .bonsai-info__template-group {
            margin-bottom: 8px;
        }
        .bonsai-info__template-group-label {
            color: #dcdcaa;
            font-size: 10px;
            font-weight: 600;
            margin-bottom: 4px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .bonsai-info__template-list {
            margin: 0;
            padding: 0;
            list-style: none;
        }
        .bonsai-info__template-item {
            padding: 3px 0;
            line-height: 1.4;
            margin-bottom: 2px;
            font-family: inherit;
            position: relative;
            padding-left: 20px;
        }
        .bonsai-info__template-item::before {
            content: "→";
            position: absolute;
            left: 0;
            color: #808080;
            font-weight: bold;
        }
        .bonsai-info__template-item--current::before {
            content: "✓";
            color: #4ec9b0;
        }
        .bonsai-info__template-item--missing::before {
            content: "✗";
            color: #f44747;
        }
        .bonsai-info__template-path {
            color: #d4d4d4;
        }
        .bonsai-info__template-path--current {
            color: #4ec9b0 !important;
            font-weight: bold;
            background: rgba(78, 201, 176, 0.1);
            padding: 2px 4px;
            border-radius: 3px;
        }
        .bonsai-info__template-path--missing {
            color: #808080;
            text-decoration: line-through;
        }
        .bonsai-info__template-path--site-specific {
            color: #9cdcfe;
        }
        .bonsai-info__note {
            font-size: 10px;
            color: #808080;
            font-style: italic;
            margin-top: 8px;
            padding: 6px 8px;
            background: rgba(128, 128, 128, 0.1);
            border-radius: 4px;
        }
        .bonsai-info__note code {
            background: rgba(206, 145, 120, 0.2);
            color: #ce9178;
            padding: 2px 4px;
            border-radius: 3px;
            font-family: inherit;
            font-size: 9px;
        }
        .bonsai-info__performance {
            border-top: 1px solid #454545;
            padding-top: 12px;
            margin-top: 12px;
        }
        .bonsai-info__performance-title {
            color: #569cd6;
            font-weight: 600;
            margin-bottom: 8px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .bonsai-info__performance-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
            margin-bottom: 8px;
        }
        .bonsai-info__performance-item {
            background: rgba(86, 156, 214, 0.1);
            padding: 6px 8px;
            border-radius: 4px;
            font-size: 11px;
        }
        .bonsai-info__performance-label {
            color: #9cdcfe;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 2px;
        }
        .bonsai-info__performance-value {
            color: #4ec9b0;
            font-weight: bold;
            font-size: 12px;
        }
        .bonsai-info__performance-value--warning {
            color: #ffcc02;
        }
        .bonsai-info__performance-value--error {
            color: #f44747;
        }
        .bonsai-info__checkpoints {
            margin-top: 8px;
        }
        .bonsai-info__checkpoints-title {
            color: #dcdcaa;
            font-size: 10px;
            font-weight: 600;
            margin-bottom: 4px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .bonsai-info__checkpoint {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 2px 0;
            font-size: 10px;
            border-bottom: 1px solid rgba(68, 68, 68, 0.3);
        }
        .bonsai-info__checkpoint:last-child {
            border-bottom: none;
        }
        .bonsai-info__checkpoint-name {
            color: #d4d4d4;
        }
        .bonsai-info__checkpoint-time {
            color: #4ec9b0;
            font-weight: 500;
        }
        .bonsai-info__cache-stats {
            border-top: 1px solid #454545;
            padding-top: 12px;
            margin-top: 12px;
        }
        .bonsai-info__cache-title {
            color: #569cd6;
            font-weight: 600;
            margin-bottom: 8px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .bonsai-info__cache-overview {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 6px;
            margin-bottom: 8px;
        }
        .bonsai-info__cache-metric {
            background: rgba(78, 201, 176, 0.1);
            padding: 6px 8px;
            border-radius: 4px;
            text-align: center;
        }
        .bonsai-info__cache-metric-label {
            color: #9cdcfe;
            font-size: 9px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 2px;
        }
        .bonsai-info__cache-metric-value {
            color: #4ec9b0;
            font-weight: bold;
            font-size: 11px;
        }
        .bonsai-info__cache-details {
            font-size: 10px;
        }
        .bonsai-info__cache-type {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 2px 0;
            border-bottom: 1px solid rgba(68, 68, 68, 0.3);
        }
        .bonsai-info__cache-type:last-child {
            border-bottom: none;
        }
        .bonsai-info__cache-type-name {
            color: #d4d4d4;
        }
        .bonsai-info__cache-type-stats {
            color: #4ec9b0;
            font-weight: 500;
        }
    </style>
{% endapply %}
<div class="bonsai-info__hover">
    <div class="bonsai-info__text">
        <div class="bonsai-info__header">
            <div class="bonsai-info__title">Bonsai Twig Debug</div>
            <div class="bonsai-info__type-badge">{{ data.type|default('template') }}</div>
        </div>

        <div class="bonsai-info__directory">
            <div class="bonsai-info__directory-label">Template Directory</div>
            <div class="bonsai-info__directory-path">{{ data.directory }}</div>
        </div>

        {% if data.site_info is defined %}
            <div class="bonsai-info__site-context">
                <div class="bonsai-info__site-label">Site Context</div>
                {% if data.site_info.current_site %}
                    <div class="bonsai-info__site-item">
                        <span class="bonsai-info__site-key">Current Site:</span>
                        <span class="bonsai-info__site-value">{{ data.site_info.current_site }}</span>
                    </div>
                {% endif %}
                {% if data.site_info.element_site %}
                    <div class="bonsai-info__site-item">
                        <span class="bonsai-info__site-key">Element Site:</span>
                        <span class="bonsai-info__site-value">{{ data.site_info.element_site }}</span>
                    </div>
                {% endif %}
                {% if data.site_info.base_site %}
                    <div class="bonsai-info__site-item">
                        <span class="bonsai-info__site-key">Base Site:</span>
                        <span class="bonsai-info__site-value">{{ data.site_info.base_site }}</span>
                    </div>
                {% endif %}
                {% if data.site_info.fallback_site %}
                    <div class="bonsai-info__site-item">
                        <span class="bonsai-info__site-key">Fallback Site:</span>
                        <span class="bonsai-info__site-value">{{ data.site_info.fallback_site }}</span>
                    </div>
                {% endif %}
            </div>
        {% endif %}

        <div class="bonsai-info__templates">
            <div class="bonsai-info__templates-label">
                Template Resolution Hierarchy
                <span class="bonsai-info__template-count">{{ data.templates|length }} paths</span>
            </div>
            
            <div class="bonsai-info__template-hierarchy">
                {% set originalTemplates = data.templates %}
                {% set optimizedTemplates = data.optimized_templates|default([]) %}
                {% set currentTemplate = data.currentTemplate %}
                
                {% if optimizedTemplates|length > 0 and optimizedTemplates != originalTemplates %}
                    <div class="bonsai-info__template-group">
                        <div class="bonsai-info__template-group-label">Original Templates ({{ originalTemplates|length }})</div>
                        <div class="bonsai-info__template-list">
                            {% for template in originalTemplates %}
                                <div class="bonsai-info__template-item {% if template == currentTemplate %}bonsai-info__template-item--current{% else %}bonsai-info__template-item--missing{% endif %}">
                                    <span class="bonsai-info__template-path {% if template == currentTemplate %}bonsai-info__template-path--current{% else %}bonsai-info__template-path--missing{% endif %}">
                                        {{ template }}
                                    </span>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                    
                    <div class="bonsai-info__template-group">
                        <div class="bonsai-info__template-group-label">Optimized Templates ({{ optimizedTemplates|length }})</div>
                        <div class="bonsai-info__template-list">
                            {% for template in optimizedTemplates %}
                                {% set isSiteSpecific = template matches '/_(\\w+)/' or template matches '/(\\w+)/' %}
                                <div class="bonsai-info__template-item {% if template == currentTemplate %}bonsai-info__template-item--current{% else %}bonsai-info__template-item--missing{% endif %}">
                                    <span class="bonsai-info__template-path {% if template == currentTemplate %}bonsai-info__template-path--current{% elseif isSiteSpecific %}bonsai-info__template-path--site-specific{% else %}bonsai-info__template-path--missing{% endif %}">
                                        {{ template }}
                                    </span>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                {% else %}
                    <div class="bonsai-info__template-group">
                        <div class="bonsai-info__template-group-label">Template Paths ({{ originalTemplates|length }})</div>
                        <div class="bonsai-info__template-list">
                            {% for template in originalTemplates %}
                                {% set isSiteSpecific = template matches '/_(\\w+)/' or template matches '/(\\w+)/' %}
                                <div class="bonsai-info__template-item {% if template == currentTemplate %}bonsai-info__template-item--current{% else %}bonsai-info__template-item--missing{% endif %}">
                                    <span class="bonsai-info__template-path {% if template == currentTemplate %}bonsai-info__template-path--current{% elseif isSiteSpecific %}bonsai-info__template-path--site-specific{% else %}bonsai-info__template-path--missing{% endif %}">
                                        {{ template }}
                                    </span>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
            </div>
            
            <div class="bonsai-info__note">
                Templates are checked in priority order. ✓ = found, ✗ = missing, blue = site-specific
            </div>
        </div>
        
        {% if data.performance is defined %}
            <div class="bonsai-info__performance">
                <div class="bonsai-info__performance-title">Performance Metrics</div>
                
                <div class="bonsai-info__performance-grid">
                    <div class="bonsai-info__performance-item">
                        <div class="bonsai-info__performance-label">Resolution Time</div>
                        <div class="bonsai-info__performance-value {% if data.performance.resolution_time > 0.1 %}bonsai-info__performance-value--warning{% elseif data.performance.resolution_time > 0.5 %}bonsai-info__performance-value--error{% endif %}">
                            {% if data.performance.resolution_time < 0.001 %}
                                {{ (data.performance.resolution_time * 1000000)|round(2) }}μs
                            {% elseif data.performance.resolution_time < 1 %}
                                {{ (data.performance.resolution_time * 1000)|round(2) }}ms
                            {% else %}
                                {{ data.performance.resolution_time|round(3) }}s
                            {% endif %}
                        </div>
                    </div>
                    
                    {% if data.performance.memory_usage is defined and data.performance.memory_usage.delta is defined %}
                        <div class="bonsai-info__performance-item">
                            <div class="bonsai-info__performance-label">Memory Delta</div>
                            <div class="bonsai-info__performance-value {% if data.performance.memory_usage.delta > 1048576 %}bonsai-info__performance-value--warning{% elseif data.performance.memory_usage.delta > 5242880 %}bonsai-info__performance-value--error{% endif %}">
                                {% set memDelta = data.performance.memory_usage.delta %}
                                {% if memDelta < 1024 %}
                                    {{ memDelta }}B
                                {% elseif memDelta < 1048576 %}
                                    {{ (memDelta / 1024)|round(2) }}KB
                                {% else %}
                                    {{ (memDelta / 1048576)|round(2) }}MB
                                {% endif %}
                            </div>
                        </div>
                    {% endif %}
                    
                    {% if data.performance.optimization_savings is defined %}
                        <div class="bonsai-info__performance-item">
                            <div class="bonsai-info__performance-label">Paths Saved</div>
                            <div class="bonsai-info__performance-value">
                                {{ data.performance.optimization_savings }}
                            </div>
                        </div>
                    {% endif %}
                </div>
                
                {% if data.performance.checkpoints is defined and data.performance.checkpoints|length > 0 %}
                    <div class="bonsai-info__checkpoints">
                        <div class="bonsai-info__checkpoints-title">Resolution Checkpoints</div>
                        {% for checkpoint, checkpointData in data.performance.checkpoints %}
                            <div class="bonsai-info__checkpoint">
                                <span class="bonsai-info__checkpoint-name">{{ checkpoint|replace('_', ' ')|title }}</span>
                                <span class="bonsai-info__checkpoint-time">
                                    {% if checkpointData.elapsed < 0.001 %}
                                        {{ (checkpointData.elapsed * 1000000)|round(2) }}μs
                                    {% elseif checkpointData.elapsed < 1 %}
                                        {{ (checkpointData.elapsed * 1000)|round(2) }}ms
                                    {% else %}
                                        {{ checkpointData.elapsed|round(3) }}s
                                    {% endif %}
                                </span>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        {% endif %}
        
        {% if data.cache_stats is defined %}
            <div class="bonsai-info__cache-stats">
                <div class="bonsai-info__cache-title">Cache Performance</div>
                
                {% if craft.app.config.general.devMode %}
                    <div class="bonsai-info__note">
                        <strong>Caching is disabled in development mode.</strong><br>
                        Cache statistics are only available in production environments.
                        To test caching, set <code>devMode = false</code> in your config.
                    </div>
                {% else %}
                    <div class="bonsai-info__cache-overview">
                        <div class="bonsai-info__cache-metric">
                            <div class="bonsai-info__cache-metric-label">Hit Rate</div>
                            <div class="bonsai-info__cache-metric-value">{{ data.cache_stats.hit_rate }}%</div>
                        </div>
                        <div class="bonsai-info__cache-metric">
                            <div class="bonsai-info__cache-metric-label">Hits</div>
                            <div class="bonsai-info__cache-metric-value">{{ data.cache_stats.hits }}</div>
                        </div>
                        <div class="bonsai-info__cache-metric">
                            <div class="bonsai-info__cache-metric-label">Total</div>
                            <div class="bonsai-info__cache-metric-value">{{ data.cache_stats.total_requests }}</div>
                        </div>
                    </div>
                    
                    {% if data.cache_stats.by_type is defined and data.cache_stats.by_type|length > 0 %}
                        <div class="bonsai-info__cache-details">
                            {% for cacheType, typeStats in data.cache_stats.by_type %}
                                <div class="bonsai-info__cache-type">
                                    <span class="bonsai-info__cache-type-name">{{ cacheType|title }}</span>
                                    <span class="bonsai-info__cache-type-stats">
                                        {{ typeStats.hit_rate }}% ({{ typeStats.hits }}/{{ typeStats.total }})
                                    </span>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                {% endif %}
            </div>
        {% endif %}
    </div>
    {{ content|raw }}
</div>
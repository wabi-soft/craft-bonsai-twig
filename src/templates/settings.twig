{% import "_includes/forms" as forms %}

<div class="field">
    <div class="heading">
        <label>{{ "Template Resolution Strategy"|t('bonsai-twig') }}</label>
        <div class="instructions">
            <p>{{ "Controls how template paths are organized. Can be overridden per-template call or in config/bonsai-twig.php."|t('bonsai-twig') }}</p>
        </div>
    </div>
</div>

{{ forms.radioGroupField({
    label: "Strategy"|t('bonsai-twig'),
    instructions: "<strong>Section-first</strong> uses section as the primary folder (default). <strong>Type-first</strong> uses entry type as the primary folder, aligning with Craft 5's standalone entry types."|t('bonsai-twig'),
    id: 'strategy',
    name: 'strategy',
    value: settings.strategy,
    options: [
        { label: 'Section-first (default)'|t('bonsai-twig'), value: 'section' },
        { label: 'Type-first (Craft 5)'|t('bonsai-twig'), value: 'type' },
    ],
}) }}


<hr>

<details style="margin-top: 12px;">
    <summary style="cursor: pointer; color: #0d78f2;">{{ "Show example configuration"|t('bonsai-twig') }}</summary>
    <pre style="background:#f5f5f5; padding:8px; border-radius:4px; font-size: 10px; margin-top: 8px;">// config/bonsai-twig.php
return [
    'paths' => [
        'entry' => '_entry',
        'item' => '_item',
        'category' => '_category',
        'matrix' => '_matrix',
        'asset' => '_asset',
        'product' => '_product',
    ],
];</pre>
</details>
{% import "_includes/forms" as forms %}

<div class="field">
    <div class="heading">
        <label>{{ "Performance Settings"|t('bonsai-twig') }}</label>
        <div class="instructions">
            <p>{{ "Configure performance monitoring and debugging features."|t('bonsai-twig') }}</p>
        </div>
    </div>
</div>

{{ forms.lightswitchField({
    label: settings.attributeLabels.enablePerformanceMonitoring,
    instructions: settings.attributeHints.enablePerformanceMonitoring,
    id: 'enablePerformanceMonitoring',
    name: 'enablePerformanceMonitoring',
    on: settings.enablePerformanceMonitoring
}) }}

{{ forms.lightswitchField({
    label: settings.attributeLabels.enableErrorReporting,
    instructions: settings.attributeHints.enableErrorReporting,
    id: 'enableErrorReporting',
    name: 'enableErrorReporting',
    on: settings.enableErrorReporting
}) }}

<hr>

<div class="field">
    <div class="heading">
        <label>{{ "Item Templates Settings"|t('bonsai-twig') }}</label>
        <div class="instructions">
            <p>{{ settings.attributeHints.itemsTemplateElementPaths }}</p>
        </div>
    </div>
    <div class="readable">
        <strong>{{ settings.attributeLabels.itemsTemplateElementPaths }}</strong>
        <div style="margin-top:6px; font-family: monospace; white-space: pre;">{{ (settings.itemsTemplateElementPaths is iterable ? settings.itemsTemplateElementPaths|json_encode(constant('JSON_PRETTY_PRINT')) : 'false') }}</div>
        <div class="instructions">
            <p>{{ "Configure via project config (config/_bonsai-twig.php) by setting the plugin setting ‘itemsTemplateElementPaths’. Example:"|t('bonsai-twig') }}</p>
            <pre style="background:#cccccc; padding:8px; border-radius:4px; font-size: 10px;">return [
    'itemsTemplateElementPaths' => [
        'entry' => 'entry',
        'category' => 'category',
    ],
];</pre>
        </div>
    </div>
</div>

{{ forms.lightswitchField({
    label: settings.attributeLabels.nestByElementType,
    instructions: settings.attributeHints.nestByElementType ~ ' ' ~ 'If a mapping is provided in "' ~ settings.attributeLabels.itemsTemplateElementPaths ~ '", it will take precedence.' ,
    id: 'nestByElementType',
    name: 'nestByElementType',
    on: settings.nestByElementType
}) }}
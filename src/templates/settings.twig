{% import "_includes/forms" as forms %}

<div class="field">
    <div class="heading">
        <label>{{ "Template Resolution Strategy"|t('bonsai-twig') }}</label>
        <div class="instructions">
            <p>{{ "Controls how template paths are organized. Can be overridden per-template call or in config/_bonsai-twig.php."|t('bonsai-twig') }}</p>
        </div>
    </div>
</div>

{{ forms.radioGroupField({
    label: "Strategy"|t('bonsai-twig'),
    instructions: "<strong>Section-first</strong> uses section as the primary folder (default). <strong>Type-first</strong> uses entry type as the primary folder, aligning with Craft 5's standalone entry types."|t('bonsai-twig'),
    id: 'strategy',
    name: 'strategy',
    value: settings.strategy,
    options: [
        { label: 'Section-first (default)', value: 'section' },
        { label: 'Type-first (Craft 5)', value: 'type' },
    ],
}) }}

<hr>

<div class="field">
    <div class="heading">
        <label>{{ "Advanced: Item Templates Settings"|t('bonsai-twig') }}</label>
        <div class="instructions">
            <p>{{ "Generally keep this off. Enable it only if you rely on legacy patterns where categories and entry templates share a handle and you need nested item templates by element type."|t('bonsai-twig') }}</p>
        </div>
    </div>
</div>

{{ forms.lightswitchField({
    label: "Nest Item Templates by Element Type",
    instructions: "When enabled, item templates will automatically nest under item/entry/ or item/category/ based on the element type. When disabled (default), templates resolve to item/default.twig.",
    id: 'nestByElementType',
    name: 'nestByElementType',
    on: settings.nestByElementType
}) }}

<div class="field">

    <div class="instructions">
        <p><strong>{{ "Custom Element Path Mapping"|t('bonsai-twig') }}</strong></p>
        <p>{{ "For more control, configure custom path mappings in your project config file (config/_bonsai-twig.php). This overrides the toggle above."|t('bonsai-twig') }}</p>
        {% if settings.itemsTemplateElementPaths is iterable %}
            <p>{{ "Current mapping:"|t('bonsai-twig') }}</p>
            <pre style="background:#e8f5e9; padding:8px; border-radius:4px; font-size: 11px; font-family: monospace;">{{ settings.itemsTemplateElementPaths|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
        {% else %}
            <p>{{ "No custom mapping configured (using toggle setting above)."|t('bonsai-twig') }}</p>
        {% endif %}
        <details style="margin-top: 12px;">
            <summary style="cursor: pointer; color: #0d78f2;">{{ "Show example configuration"|t('bonsai-twig') }}</summary>
            <pre style="background:#f5f5f5; padding:8px; border-radius:4px; font-size: 10px; margin-top: 8px;">return [
    'itemsTemplateElementPaths' => [
        'entry' => 'entry',
        'category' => 'category',
    ],
];</pre>
        </details>
    </div>
</div>
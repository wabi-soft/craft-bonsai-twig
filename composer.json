{
    "name": "wabisoft/craft-bonsai-twig",
    "description": "Internal use template helper",
    "type": "craft-plugin",
    "version": "7.0.8",
    "require": {
        "php": ">=8.2.0",
        "craftcms/cms": "^4.4|^5.0"
    },
    "require-dev": {
        "craftcms/ecs": "dev-main",
        "craftcms/phpstan": "dev-main",
        "marcocesarato/php-conventional-changelog": "^1.16",
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "wabisoft\\bonsaitwig\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "wabisoft\\bonsaitwig\\tests\\": "tests/"
        }
    },
    "extra": {
        "handle": "_bonsai-twig",
        "name": "Bonsai Twig",
        "developer": "Wabisoft",
        "documentationUrl": "",
        "class": "wabisoft\\bonsaitwig\\BonsaiTwig"
    },
    "scripts": {
        "changelog": "conventional-changelog",
        "release": "conventional-changelog --commit",
        "release:patch": "conventional-changelog --patch --commit",
        "release:minor": "conventional-changelog --minor --commit",
        "release:major": "conventional-changelog --major --commit",
        "release:alpha": "conventional-changelog --alpha",
        "release:beta": "conventional-changelog --beta",
        "release:rc": "conventional-changelog --rc",
        "check-cs": "ecs check --ansi",
        "fix-cs": "ecs check --ansi --fix",
        "phpstan": "phpstan --memory-limit=1G",
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=unit",
        "test:integration": "phpunit --testsuite=integration",
        "test:performance": "phpunit --testsuite=performance",
        "test:coverage": "phpunit --coverage-html coverage"
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.2.0"
        },
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true
        }
    }
}